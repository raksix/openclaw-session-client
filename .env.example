# OpenClaw Session Manager - Environment Variables

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Backend (Elysia)
PORT=4000
HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=openclaw_session_manager

# Authentication
JWT_SECRET=change-this-to-a-random-secret-in-production

# OpenClaw Gateway (for connecting to actual OpenClaw sessions)
OPENCLAW_GATEWAY_URL=ws://localhost:18789
OPENCLAW_GATEWAY_TOKEN=

# Admin Seed (only used when running seed script)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@openclaw.local
ADMIN_PASSWORD=admin123change
